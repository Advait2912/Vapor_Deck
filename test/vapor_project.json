    {
      "index": 1,
      "title": "Blockchain and Its Future Scope",
      "html": "<section class=\"slide\" style=\"width: 100%; height: 100%; min-height: 100vh; box-sizing: border-box; display: flex; flex-direction: column; justify-content: center; align-items: center; background: var(--bg); color: var(--text); font-family: var(--font-body); position: relative; overflow: hidden;\">\n  <style>\n    .hero-container {\n      text-align: center;\n      z-index: 10;\n      max-width: 80%;\n      margin: 0 auto;\n    }\n    .hero-title {\n      font-family: var(--font-head);\n      font-size: clamp(2.5rem, 6vw, 5rem);\n      line-height: 1.1;\n      margin-bottom: 1.5rem;\n      background: linear-gradient(135deg, var(--text) 0%, var(--accent) 100%);\n      -webkit-background-clip: text;\n      -webkit-text-fill-color: transparent;\n      font-weight: 800;\n    }\n    .hero-subtitle {\n      font-size: clamp(1.1rem, 2vw, 1.8rem);\n      color: var(--text-muted);\n      max-width: 700px;\n      margin: 0 auto 3rem auto;\n      line-height: 1.6;\n    }\n    .hero-grid {\n      display: grid;\n      grid-template-columns: repeat(3, 1fr);\n      gap: 2rem;\n      margin-top: 4rem;\n    }\n    .grid-item {\n      padding: 1.5rem;\n      border: 1px solid var(--border);\n      background: var(--surface);\n      border-radius: 12px;\n      font-size: clamp(0.8rem, 1.2vw, 1rem);\n      color: var(--text-muted);\n      transition: all 0.3s ease;\n    }\n    .grid-item:hover {\n      border-color: var(--accent);\n      box-shadow: 0 0 20px var(--accent-glow);\n      transform: translateY(-5px);\n    }\n    .grid-item strong {\n      display: block;\n      color: var(--accent);\n      margin-bottom: 0.5rem;\n      font-size: 1.2em;\n    }\n    .bg-decor {\n      position: absolute;\n      width: 600px;\n      height: 600px;\n      background: radial-gradient(circle, var(--accent-glow) 0%, transparent 70%);\n      opacity: 0.15;\n      filter: blur(60px);\n      z-index: 1;\n      pointer-events: none;\n    }\n    .decor-1 { top: -20%; right: -10%; }\n    .decor-2 { bottom: -20%; left: -10%; }\n    .reveal {\n      opacity: 0;\n      transform: translateY(20px);\n      animation: revealIn 0.8s forwards;\n      animation-delay: var(--delay);\n    }\n    @keyframes revealIn {\n      to { opacity: 1; transform: translateY(0); }\n    }\n  </style>\n\n  <div class=\"bg-decor decor-1\"></div>\n  <div class=\"bg-decor decor-2\"></div>\n\n  <div class=\"hero-container\">\n    <h1 class=\"hero-title reveal\" style=\"--delay: 0.2s\">Blockchain and Its Future Scope</h1>\n    <p class=\"hero-subtitle reveal\" style=\"--delay: 0.5s\">\n      Beyond digital currency: exploring the evolution of trust and the architectural shift toward a truly decentralized global infrastructure.\n    </p>\n    \n    <div class=\"hero-grid\">\n      <div class=\"grid-item reveal\" style=\"--delay: 0.8s\">\n        <strong>Digital Trust</strong>\n        Evolution from centralized authorities to cryptographic verification.\n      </div>\n      <div class=\"grid-item reveal\" style=\"--delay: 1s\">\n        <strong>Infrastructure</strong>\n        Scaling from niche cryptocurrency to the backbone of global data.\n      </div>\n      <div class=\"grid-item reveal\" style=\"--delay: 1.2s\">\n        <strong>Web 3.0</strong>\n        Redefining the internet through user-owned protocols and sovereignty.\n      </div>\n    </div>\n  </div>\n</section>",
      "snapshot_b64": null,
      "approved": true
