{
  "index": 5,
  "title": "Building Decentralized Applications (dApps)",
  "html": "<section class=\"slide\" style=\"width: 100%; height: 100%; min-height: 100vh; box-sizing: border-box; display: flex; flex-direction: column; justify-content: center; align-items: center; background-color: var(--bg); color: var(--text); font-family: var(--font-body); padding: 2rem;\">\n  <style>\n    .slide-content {\n      max-width: 900px;\n      width: 100%;\n      text-align: left;\n    }\n    .slide-title {\n      font-family: var(--font-head);\n      font-size: clamp(1.5rem, 4vw, 3rem);\n      color: var(--accent);\n      margin-bottom: 2rem;\n      text-shadow: 0 0 10px var(--accent-glow);\n    }\n    .dapp-architecture {\n      display: flex;\n      flex-direction: column;\n      gap: 1.5rem;\n      position: relative;\n    }\n    .arch-step {\n      display: grid;\n      grid-template-columns: auto 1fr;\n      gap: 1.5rem;\n      align-items: center;\n      background: var(--surface);\n      border: 1px solid var(--border);\n      padding: 1.5rem;\n      border-radius: 12px;\n      transition: transform 0.3s ease;\n    }\n    .arch-step:hover {\n      border-color: var(--accent);\n      transform: translateX(10px);\n    }\n    .step-number {\n      font-family: var(--font-head);\n      font-size: 2rem;\n      color: var(--accent);\n      font-weight: bold;\n      text-align: center;\n      line-height: 1;\n    }\n    .step-text h3 {\n      font-family: var(--font-head);\n      margin: 0 0 0.5rem 0;\n      font-size: clamp(1.1rem, 2vw, 1.5rem);\n    }\n    .step-text p {\n      margin: 0;\n      color: var(--text-muted);\n      font-size: clamp(0.9rem, 1.8vw, 1.1rem);\n      line-height: 1.5;\n    }\n    .reveal {\n      opacity: 0;\n      transform: translateY(20px);\n      animation: fadeInUp 0.6s forwards;\n      animation-delay: var(--delay);\n    }\n    @keyframes fadeInUp {\n      to {\n        opacity: 1;\n        transform: translateY(0);\n      }\n    }\n    .connector {\n      width: 2px;\n      height: 20px;\n      background: var(--border);\n      margin-left: 2rem;\n    }\n  </style>\n\n  <div class=\"slide-content\">\n    <h1 class=\"slide-title reveal visible\" style=\"--delay: 0.2s\">Building Decentralized Applications (dApps)</h1>\n    \n    <div class=\"dapp-architecture\">\n      <div class=\"arch-step reveal visible\" style=\"--delay: 0.5s\">\n        <div class=\"step-number\">01</div>\n        <div class=\"step-text\">\n          <h3>Wallet Connectivity &amp; Auth</h3>\n          <p>Replacing traditional passwords with cryptographic signatures. Users authenticate via providers like MetaMask or WalletConnect to establish identity.</p>\n        </div>\n      </div>\n\n      <div class=\"connector reveal visible\" style=\"--delay: 0.7s\"></div>\n\n      <div class=\"arch-step reveal visible\" style=\"--delay: 0.9s\">\n        <div class=\"step-number\">02</div>\n        <div class=\"step-text\">\n          <h3>Frontend Integration</h3>\n          <p>Using <strong>Ethers.js</strong> or <strong>Web3.js</strong> as the bridge to communicate with the blockchain, calling smart contract functions and listening to events.</p>\n        </div>\n      </div>\n\n      <div class=\"connector reveal visible\" style=\"--delay: 1.1s\"></div>\n\n      <div class=\"arch-step reveal visible\" style=\"--delay: 1.3s\">\n        <div class=\"step-number\">03</div>\n        <div class=\"step-text\">\n          <h3>Decentralized Storage</h3>\n          <p>Offloading heavy assets from the chain. <strong>IPFS</strong> and <strong>Filecoin</strong> ensure content-addressed persistence for metadata, images, and documents.</p>\n        </div>\n      </div>\n\n      <div class=\"connector reveal visible\" style=\"--delay: 1.5s\"></div>\n\n      <div class=\"arch-step reveal visible\" style=\"--delay: 1.7s\">\n        <div class=\"step-number\">04</div>\n        <div class=\"step-text\">\n          <h3>The Oracle Layer</h3>\n          <p>Bridging the gap between on-chain logic and off-chain reality. Oracles (e.g., Chainlink) feed real-world price data, weather, or API results into smart contracts.</p>\n        </div>\n      </div>\n    </div>\n  </div>\n</section>",
