  "title": "Smart Contract Logic and Execution",
  "html": "<section class=\"slide\" style=\"width: 100%; height: 100%; min-height: 100vh; box-sizing: border-box; background-color: var(--bg); color: var(--text); font-family: var(--font-body); display: flex; flex-direction: column; overflow: hidden;\">\n  <style>\n    .slide-grid {\n      display: grid;\n      grid-template-columns: 1.2fr 0.8fr;\n      gap: 2rem;\n      padding: 2rem;\n      height: calc(100% - 80px);\n      align-items: center;\n    }\n    .slide-header {\n      padding: 2rem 2rem 0 2rem;\n      font-family: var(--font-head);\n    }\n    .slide-title {\n      font-size: clamp(1.5rem, 3vw, 2.5rem);\n      color: var(--text);\n      margin: 0;\n    }\n    .code-container {\n      background: var(--code-bg);\n      border: 1px solid var(--border);\n      border-radius: 8px;\n      padding: 1rem;\n      position: relative;\n      box-shadow: 0 10px 30px rgba(0,0,0,0.5);\n    }\n    .code-container pre {\n      margin: 0;\n      font-family: 'Cascadia Code', 'Fira Code', monospace;\n      font-size: clamp(0.8rem, 1.2vw, 1.1rem);\n      line-height: 1.5;\n    }\n    .content-list {\n      list-style: none;\n      padding: 0;\n    }\n    .content-item {\n      margin-bottom: 1.5rem;\n      padding-left: 1.5rem;\n      border-left: 3px solid var(--accent);\n      transition: transform 0.3s ease;\n    }\n    .content-item:hover {\n      transform: translateX(10px);\n    }\n    .item-title {\n      font-weight: bold;\n      font-size: clamp(1rem, 1.5vw, 1.25rem);\n      color: var(--accent);\n      display: block;\n      margin-bottom: 0.25rem;\n    }\n    .item-desc {\n      font-size: clamp(0.9rem, 1.2vw, 1rem);\n      color: var(--text-muted);\n    }\n    .reveal {\n      opacity: 0;\n      transform: translateY(20px);\n      animation: revealIn 0.6s forwards;\n      animation-delay: var(--delay);\n    }\n    @keyframes revealIn {\n      to { opacity: 1; transform: translateY(0); }\n    }\n    .highlight-line {\n      background: rgba(var(--accent-glow), 0.2);\n      display: block;\n      width: 100%;\n    }\n  </style>\n\n  <div class=\"slide-header\">\n    <h1 class=\"slide-title\">Smart Contract Logic and Execution</h1>\n  </div>\n\n  <div class=\"slide-grid\">\n    <div class=\"code-container reveal visible\" style=\"--delay: 0.2s\">\n      <pre class=\"language-solidity\" tabindex=\"0\"><code class=\"language-solidity\">\ncontract Vault {\n    // State management: Storage costs Gas\n    mapping(address =&gt; uint256) public balances;\n\n    function deposit() external payable {\n        // Deterministic logic: No random API calls\n        require(msg.value &gt; 0, \"Must send ETH\");\n        \n        // Gas optimization: Local cache of state\n        uint256 currentBal = balances[msg.sender];\n        balances[msg.sender] = currentBal + msg.value;\n    }\n\n    function withdraw(uint256 _amount) external {\n        // Security: Check-Effects-Interactions pattern\n        require(balances[msg.sender] &gt;= _amount, \"Insufficient\");\n        \n        balances[msg.sender] -= _amount;\n        payable(msg.sender).transfer(_amount);\n    }\n}\n      </code></pre>\n    </div>\n\n    <div class=\"content-area\">\n      <ul class=\"content-list\">\n        <li class=\"content-item reveal visible\" style=\"--delay: 0.4s\">\n          <span class=\"item-title\">Deterministic Execution</span>\n          <span class=\"item-desc\">Contracts must behave identically across all nodes. No external API calls; all data must be on-chain.</span>\n        </li>\n        <li class=\"content-item reveal visible\" style=\"--delay: 0.6s\">\n          <span class=\"item-title\">Solidity &amp; Rust</span>\n          <span class=\"item-desc\">Industry standards for trust: Solidity (EVM) and Rust (Solana/Polkadot) focus on memory safety and strict typing.</span>\n        </li>\n        <li class=\"content-item reveal visible\" style=\"--delay: 0.8s\">\n          <span class=\"item-title\">Gas &amp; State Optimization</span>\n          <span class=\"item-desc\">Every state change costs \"Gas\". Optimizing storage slots is critical for scalability and cost-reduction.</span>\n        </li>\n        <li class=\"content-item reveal visible\" style=\"--delay: 1.0s\">\n          <span class=\"item-title\">Security Auditing</span>\n          <span class=\"item-desc\">Preventing re-entrancy and integer overflows through formal verification and rigorous peer review.</span>\n        </li>\n      </ul>\n    </div>\n  </div>\n</section>",
