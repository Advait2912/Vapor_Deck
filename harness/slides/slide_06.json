{
  "index": 6,
  "title": "Pathways to a Sustainable Future",
  "html": "\n  <section class=\"slide\" style=\"width: 100%; height: 100%; min-height: 100vh; box-sizing: border-box; display: flex; flex-direction: column; justify-content: center; padding: clamp(2rem, 5vw, 5rem); background-color: var(--bg); color: var(--text); font-family: var(--font-body);\">\n  <style>\n    .slide {\n      position: relative;\n      overflow: hidden;\n    }\n    .slide-content {\n      max-width: 900px;\n      margin: 0 auto;\n      width: 100%;\n    }\n    .slide-title {\n      font-family: var(--font-head);\n      font-size: clamp(2rem, 4vw, 3.5rem);\n      color: var(--text);\n      margin-bottom: 3rem;\n      position: relative;\n      display: inline-block;\n    }\n    .slide-title::after {\n      content: '';\n      position: absolute;\n      bottom: -10px;\n      left: 0;\n      width: 60px;\n      height: 4px;\n      background: var(--accent);\n      box-shadow: 0 0 10px var(--accent-glow);\n    }\n    .pathways-list {\n      list-style: none;\n      padding: 0;\n      margin: 0;\n      display: flex;\n      flex-direction: column;\n      gap: 1.5rem;\n    }\n    .pathway-item {\n      display: flex;\n      align-items: center;\n      gap: 1rem;\n      padding: 1.5rem;\n      background: var(--surface);\n      border: 1px solid var(--border);\n      border-radius: 0.5rem;\n      transition: transform 0.3s ease, border-color 0.3s ease;\n      cursor: pointer;\n    }\n    .pathway-item:hover {\n      transform: translateX(10px);\n      border-color: var(--accent);\n    }\n    .bullet-icon {\n      width: 12px;\n      height: 12px;\n      background: var(--accent);\n      border-radius: 50%;\n      box-shadow: 0 0 8px var(--accent-glow);\n      flex-shrink: 0;\n    }\n    .pathway-text {\n      font-size: clamp(1.1rem, 2vw, 1.5rem);\n      line-height: 1.4;\n    }\n    .reveal {\n      opacity: 0;\n      transform: translateY(20px);\n      animation: revealIn 0.6s forwards;\n      animation-delay: var(--delay);\n    }\n    @keyframes revealIn {\n      to {\n        opacity: 1;\n        transform: translateY(0);\n      }\n    }\n  </style>\n\n  <div class=\"slide-content\">\n    <h1 class=\"slide-title reveal visible\" style=\"--delay: 0.2s\">Pathways to a Sustainable Future</h1>\n    \n    <ul class=\"pathways-list\">\n      <li class=\"pathway-item reveal visible\" style=\"--delay: 0.4s\">\n        <div class=\"bullet-icon\"></div>\n        <span class=\"pathway-text\">Large-scale reforestation and advanced carbon capture technologies</span>\n      </li>\n      <li class=\"pathway-item reveal visible\" style=\"--delay: 0.6s\">\n        <div class=\"bullet-icon\"></div>\n        <span class=\"pathway-text\">Transitioning to circular economy principles to eliminate waste</span>\n      </li>\n      <li class=\"pathway-item reveal visible\" style=\"--delay: 0.8s\">\n        <div class=\"bullet-icon\"></div>\n        <span class=\"pathway-text\">Implementing systemic policy changes and binding international treaties</span>\n      </li>\n      <li class=\"pathway-item reveal visible\" style=\"--delay: 1.0s\">\n        <div class=\"bullet-icon\"></div>\n        <span class=\"pathway-text\">Decarbonizing industrial grids via sustainable energy infrastructure</span>\n      </li>\n      <li class=\"pathway-item reveal visible\" style=\"--delay: 1.2s\">\n        <div class=\"bullet-icon\"></div>\n        <span class=\"pathway-text\">Integrating regenerative agriculture to restore soil health</span>\n      </li>\n    </ul>\n  </div>\n</section>\n  \n\n\n  ",
